generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String   @id @default(uuid())
  name      String
  category  String
  price     Int
  rating    Float    @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([category])
  @@index([price])
  @@index([createdAt])
  @@map("products")
}
